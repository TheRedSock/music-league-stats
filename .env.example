# Pooled connection string for application runtime queries.
DATABASE_URL=postgresql://user:password@pooled-host/database?sslmode=require

# Direct, non-pooled connection string for Drizzle migrations.
DATABASE_URL_DIRECT=postgresql://user:password@direct-host/database?sslmode=require

# Password used only for the private /admin sign-in (no user table).
ADMIN_PASSWORD=replace-with-a-strong-unique-password

# HMAC signing key for HttpOnly admin sessions; use 32+ random characters.
# Example generator: openssl rand -base64 48
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Spotify Web API (Client Credentials) — preferred for collab artist splits via track.artists[].
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# MusicBrainz OAuth app credentials (optional fallback / enrichment).
# Register at https://musicbrainz.org/account/applications
MUSICBRAINZ_CLIENT_ID=
MUSICBRAINZ_CLIENT_SECRET=
MUSICBRAINZ_USER_AGENT=music-league-stats/1.0 (contact@example.com)

# Optional Last.fm API key (genre/tag enrichment only; not needed for artist splits).
LASTFM_API_KEY=
